# Credenciales del conector a siHosp (NO commitear el .env real).
SIHOSP_USER=
SIHOSP_PASS=

# Opcional: ruta a un Chromium preinstalado (si no usás `npx playwright install`).
# SIHOSP_CHROMIUM=/opt/pw-browsers/chromium-1194/chrome-linux/chrome

# Opcional: API key de Anthropic para el análisis de imágenes.
# ANTHROPIC_API_KEY=
